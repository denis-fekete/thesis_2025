    @misc{hurta,
    abstract = {Cílem této práce je vytvoření podpůrné aplikace ke slovní asociační deskové hře Krycí jména na mobilní telefony s operačním systémem Android. Řešení se skládá z detekce a rozpoznání herního plánu za pomoci knihoven OpenCV a Tess-two a nástrojů Google Firebase ML Kit a následovného poskytnutí podpory v průběhu hry včetně volitelné úrovně jejího ulehčení a možnosti hry na více zařízeních díky službě Hry Google Play. Tyto funkce motivují uživatele k dalšímu užívání aplikace a poskytnutí dat ve formě vygenerovaného záznamu hry, užitečného pro další vývoj a ověřování asociačních modelů nebo strategií pro automatické hraní.},
    publisher = {Vysoké učení technické v Brně. Fakulta informačních technologií},
