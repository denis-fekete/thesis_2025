    }
    
    @misc{grossman,
    abstract = {Tato bakalářská práce se zabývá tvorbou aplikace pro podporu hraní společenské hry Krycí jména pro zařízení s operačním systémem Android. Aplikace pomáhá uživateli se strategií a usnadňuje rozhodování při podávání nápovědy. V práci nejprve probírám stávající řešení a jejich nedostatky. Na základě těchto poznatků rozebírám navržené řešení a poté i samotnou implementaci pomocí programovacího jazyka Java, do které patří uložení dat pomocí databázového systému nebo také rozpoznávání obrazu. Závěrem provádím a detailně popisuji uživatelské testování a důležité poznatky z něho vyplývající.},
    publisher = {Vysoké učení technické v Brně. Fakulta informačních technologií},
